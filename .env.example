# keyboard.wtf.2 hackathon configuration
# Copy to .env.local for local development. Do not commit real secrets.

GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro-preview
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_VERTEX_LOCATION=global

GOOGLE_CLOUD_PROJECT_ID=keyboard-wtf-agent
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_RUN_REGION=asia-south1
GOOGLE_CLOUD_RUN_SERVICE_NAME=keyboard-wtf-agent

ELASTICSEARCH_URL=https://your-elasticsearch-endpoint:443
ELASTICSEARCH_API_KEY=replace-with-elasticsearch-api-key
KIBANA_URL=https://your-kibana-endpoint
ELASTIC_AGENT_BUILDER_MCP_URL=https://your-kibana-endpoint/api/agent_builder/mcp
ELASTIC_MCP_API_KEY=replace-with-elastic-mcp-api-key

ELASTIC_INDEX_MEMORIES=keyboard_wtf_memories
ELASTIC_INDEX_ACTIONS=keyboard_wtf_actions
ELASTIC_INDEX_CHATS=keyboard_wtf_chats
ELASTIC_INDEX_FAILURES=keyboard_wtf_failures

DEFAULT_USER_ID=tanushshah2006
DEFAULT_DEVICE_ID=tanush-windows-demo
LOCAL_BRIDGE_PORT=8787
WEB_DASHBOARD_ORIGIN=http://localhost:8080

# Optional guard for future admin/debug routes. Keep disabled for demos.
ENABLE_ADMIN_ROUTES=false
