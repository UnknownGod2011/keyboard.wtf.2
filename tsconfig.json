{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "site/dist",
    "rootDir": "site/src"
  },
  "include": ["site/src/**/*.ts"],
  "exclude": ["node_modules", "site/dist"]
}
